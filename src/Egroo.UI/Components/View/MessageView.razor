@if (IsCurrentUser)
{
    <MudStack Row Justify="Justify.FlexEnd" Class="mb-1">
        <MudPaper Class="pa-3 msg-bubble msg-bubble-current" Elevation="0"
                  Style="max-width: 75%; border-radius: 16px 16px 4px 16px; background: var(--mud-palette-primary); color: var(--mud-palette-primary-text);">
            <MarkdownContent Content="@Content" />
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mt-1" Spacing="1">
                <MudText Typo="Typo.caption" Style="opacity: 0.7; font-size: 0.7rem;">@Date</MudText>
                @if (SentOnDate is not null && SeenOnDate is not null)
                {
                    <MudIcon Icon="@Icons.Material.Filled.DoneAll" Size="Size.Small"
                             Style="font-size: 0.875rem; opacity: 0.7;" />
                }
                else if (SentOnDate is not null)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                             Style="font-size: 0.875rem; opacity: 0.7;" />
                }
            </MudStack>
        </MudPaper>
    </MudStack>
}
else
{
    <MudStack Row Justify="Justify.FlexStart" Class="mb-1" Spacing="2">
        @if (IsAgent)
        {
            <MudAvatar Color="Color.Info" Size="Size.Small" Style="align-self: flex-end;">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
            </MudAvatar>
        }
        else
        {
            <MudAvatar Color="Color.Secondary" Size="Size.Small" Style="align-self: flex-end;">
                @DisplayName?.ToUpper()[0]
            </MudAvatar>
        }
        <MudPaper Class="pa-3 msg-bubble msg-bubble-other" Elevation="0"
                  Style="max-width: 75%; border-radius: 16px 16px 16px 4px; background: var(--mud-palette-surface);">
            <MudText Typo="Typo.caption" Color="@(IsAgent ? Color.Info : Color.Primary)" Style="font-weight: 600;">@DisplayName</MudText>
            <MarkdownContent Content="@Content" />
            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 0.7rem;" Class="mt-1">@Date</MudText>
        </MudPaper>
    </MudStack>
}

@code {
    [Parameter]
    public string? DisplayName { get; set; }
    [Parameter]
    public string? Content { get; set; }
    [Parameter]
    public string? Date { get; set; }
    [Parameter]
    public bool IsCurrentUser { get; set; }
    [Parameter]
    public bool IsAgent { get; set; }
    [Parameter]
    public DateTimeOffset? SentOnDate { get; set; }
    [Parameter]
    public DateTimeOffset? SeenOnDate { get; set; }
}
