@using FluentValidation
@using System.Text.Json
@using Egroo.UI.Components.Layout
@using Egroo.UI.Constants
@using Egroo.UI.Models
@using jihadkhawaja.chat.client
@using jihadkhawaja.chat.client.Core

@using jihadkhawaja.chat.shared.Models

@inject StorageService StorageService
@inject SessionStorage SessionStorage
@inject NavigationManager NavigationManager
@inject IAuthClient ChatAuthService
@inject ISnackbar Snackbar

<div style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px;">
    <MudStack AlignItems="AlignItems.Center" Spacing="6" Style="width: 100%; max-width: 420px;">
        <!-- Logo & Branding -->
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudImage Src="_content/Egroo.UI/favicon-32x32.png" Alt="Egroo" Width="40" Height="40" />
            <MudText Typo="Typo.h5" Style="font-weight: 700; letter-spacing: -0.02em;">Welcome back</MudText>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.5);">
                Sign in to continue to Egroo
            </MudText>
        </MudStack>

        <!-- Sign In Card -->
        <MudPaper Class="pa-6 rounded-xl" Elevation="0" Style="width: 100%; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
            <MudForm @ref="form" ValidationDelay="0">
                <MudStack Spacing="4">
                    <MudTextField @bind-Value="Username"
                                  Immediate="true"
                                  Required="true"
                                  Validation="@(new Func<string, IEnumerable<string>>(NotEmpty))"
                                  Label="Username" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="Password"
                                  Immediate="true"
                                  Required="true"
                                  Validation="@(new Func<string, IEnumerable<string>>(NotEmpty))"
                                  Label="Password" InputType="InputType.Password" Variant="Variant.Outlined" />
                    <MudButton OnClick="Submit" Disabled="@IsBusy" ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth
                               Style="border-radius: 12px; height: 48px; font-size: 0.95rem; text-transform: none;">
                        @if (IsBusy)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate />
                        }
                        else
                        {
                            <span>Sign In</span>
                        }
                    </MudButton>
                </MudStack>
            </MudForm>
        </MudPaper>

        <!-- Footer links -->
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.5);">Don't have an account?</MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/signup"
                       Style="text-transform: none; font-weight: 600;">Sign Up</MudButton>
        </MudStack>
        <MudButton Variant="Variant.Text" Color="Color.Default" Href="/" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Style="text-transform: none; color: rgba(255,255,255,0.4);">
            Back to home
        </MudButton>
    </MudStack>
</div>

@code {
    MudForm form;

    string Username { get; set; }
    string Password { get; set; }
    bool IsBusy = false;

    private IEnumerable<string> NotEmpty(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            yield return "Field is required!";
        }
    }

    private async Task Submit()
    {
        IsBusy = true;
        await form.Validate();

        if (!form.IsValid)
        {
            Snackbar.Add("Please be sure to fill all fields.", MudBlazor.Severity.Error);
            IsBusy = false;
            return;
        }

        try
        {
            // Use the strongly-typed AuthResponse from ChatAuthService.SignIn.
            var result = await ChatAuthService.SignIn(Username, Password);

            if (result == null || !result.Success)
            {
                Snackbar.Add(result?.Message ?? "Failed to sign in. Please try again.", MudBlazor.Severity.Error);
                IsBusy = false;
                return;
            }

            // Retrieve token and user id from the response.
            var token = result.Token;
            var userId = result.UserId;

            if (string.IsNullOrWhiteSpace(token) || userId == null)
            {
                Snackbar.Add("Invalid server response.", MudBlazor.Severity.Error);
                IsBusy = false;
                return;
            }

            // Save token in storage based on the current platform.
            switch (ClientModel.CurrentFrameworkPlatform)
            {
                case FrameworkPlatform.MAUI:
                    StorageService.CreateDirectory(ClientModel.AppDataPath);
                    StorageService.WriteToJsonFile("token", ClientModel.AppDataPath, token, false, true);
                    break;
                case FrameworkPlatform.WASM:
                case FrameworkPlatform.SERVER:
                    await StorageService.SetLocalStorage("token", token);
                    break;
                default:
                    throw new Exception("CurrentFrameworkPlatform parameter is undefined.");
            }

            // Update session storage with token and user information.
            SessionStorage.Token = token;
            SessionStorage.User = new UserDto
                {
                    Id = userId.Value,
                    Username = Username // Optionally, update with a server-provided username.
                };

            // Initialize and start the SignalR connection.
            ChatSignalR.Initialize(Source.HubConnectionURL, SessionStorage.Token);
            await ChatSignalR.HubConnection.StartAsync();

            // Navigate to the channels page.
            NavigationManager.NavigateTo("/channels", true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An error occurred: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            IsBusy = false;
        }
    }
}
