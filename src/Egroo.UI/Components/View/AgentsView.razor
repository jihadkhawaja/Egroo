@using jihadkhawaja.chat.client.Services
@inherits ProtectedViewBase

@inject SessionStorage SessionStorage
@inject NavigationManager NavigationManager
@inject AgentService AgentService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@if (IsBusy)
{
    <MudProgressLinear Indeterminate Color="Color.Default" />
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 pt-4">
        <MudStack Class="mb-6" Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">AI Agents</MudText>
            <MudButton OnClick="OpenCreateDialog" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add">New Agent</MudButton>
        </MudStack>

        @if (agents is null || agents.Length == 0)
        {
            <MudPaper Class="pa-8" Elevation="0">
                <MudStack AlignItems="AlignItems.Center" Spacing="4">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.h6" Color="Color.Default">No agents yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Start with the basics, then keep going in the same setup flow to add knowledge, skills, and tools.
                    </MudText>
                    <MudButton OnClick="OpenCreateDialog" Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add">Create Agent</MudButton>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudGrid>
                @foreach (var agent in agents)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="4" Class="rounded-lg" Style="height: 100%;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar Color="@GetProviderColor(agent.Provider)" Size="Size.Medium">
                                        <MudIcon Icon="@Icons.Material.Filled.SmartToy" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@agent.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @agent.Provider — @agent.Model
                                    </MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudSwitch T="bool" Value="@agent.IsActive" Color="Color.Success"
                                               ValueChanged="@(val => ToggleAgent(agent, val))" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                @if (!string.IsNullOrWhiteSpace(agent.Description))
                                {
                                    <MudText Typo="Typo.body2" Class="mb-2" Style="max-height: 60px; overflow: hidden;">
                                        @agent.Description
                                    </MudText>
                                }
                                <MudStack Row Spacing="1" Class="mt-2">
                                    @if (agent.IsActive)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Active</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Inactive</MudChip>
                                    }
                                    @if (agent.IsPublished)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Published</MudChip>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">
                                            @(agent.AddPermission == AgentAddPermission.OwnerOnly ? "Owner Only" : "Shared")
                                        </MudChip>
                                    }
                                </MudStack>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                                           StartIcon="@Icons.Material.Filled.Chat"
                                           OnClick="@(() => OpenChat(agent))"
                                           Disabled="@(!agent.IsActive)">Chat</MudButton>
                                <MudButton Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                                           StartIcon="@Icons.Material.Filled.Edit"
                                           OnClick="@(() => OpenEditDialog(agent))">Edit Setup</MudButton>
                                <MudSpacer />
                                <MudTooltip Text="@(agent.IsPublished ? "Unpublish" : "Publish")">
                                    <MudIconButton Size="Size.Small"
                                                   Color="@(agent.IsPublished ? Color.Info : Color.Default)"
                                                   Icon="@(agent.IsPublished ? Icons.Material.Filled.Public : Icons.Material.Filled.PublicOff)"
                                                   OnClick="@(() => TogglePublish(agent))" />
                                </MudTooltip>
                                <MudIconButton Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Delete"
                                               OnClick="@(() => DeleteAgentConfirm(agent))" />
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudContainer>
}

@code {
    private AgentDefinition[]? agents;

    protected override async Task OnAccessAsync()
    {
        await LoadAgents();
    }

    private async Task LoadAgents()
    {
        IsBusy = true;
        StateHasChanged();

        try
        {
            agents = await AgentService.GetAgents();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load agents: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsBusy = false;
            StateHasChanged();
        }
    }

    private void OpenCreateDialog()
    {
        NavigationManager.NavigateTo("/agents/new");
    }

    private void OpenEditDialog(AgentDefinition agent)
    {
        NavigationManager.NavigateTo($"/agents/{agent.Id}/edit");
    }

    private async Task ToggleAgent(AgentDefinition agent, bool active)
    {
        agent.IsActive = active;
        var success = await AgentService.UpdateAgent(agent);
        if (!success)
        {
            agent.IsActive = !active;
            Snackbar.Add("Failed to update agent status.", Severity.Error);
        }
        StateHasChanged();
    }

    private async Task DeleteAgentConfirm(AgentDefinition agent)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Delete Agent",
            $"Are you sure you want to delete \"{agent.Name}\"? This will remove all conversations, knowledge, and tools associated with this agent.",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            var success = await AgentService.DeleteAgent(agent.Id);
            if (success)
            {
                Snackbar.Add("Agent deleted.", Severity.Success);
                await LoadAgents();
            }
            else
            {
                Snackbar.Add("Failed to delete agent.", Severity.Error);
            }
        }
    }

    private void OpenChat(AgentDefinition agent)
    {
        NavigationManager.NavigateTo($"/agent/chat/{agent.Id}/{Uri.EscapeDataString(agent.Name)}");
    }

    private async Task TogglePublish(AgentDefinition agent)
    {
        bool success;
        if (agent.IsPublished)
        {
            success = await AgentService.UnpublishAgent(agent.Id);
        }
        else
        {
            success = await AgentService.PublishAgent(agent.Id);
        }

        if (success)
        {
            agent.IsPublished = !agent.IsPublished;
            Snackbar.Add(agent.IsPublished ? "Agent published." : "Agent unpublished.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to update publish status.", Severity.Error);
        }
        StateHasChanged();
    }

    private static Color GetProviderColor(LlmProvider provider)
    {
        return provider switch
        {
            LlmProvider.OpenAI => Color.Success,
            LlmProvider.AzureOpenAI => Color.Info,
            LlmProvider.Anthropic => Color.Warning,
            LlmProvider.Ollama => Color.Secondary,
            _ => Color.Default
        };
    }
}
