@using jihadkhawaja.chat.client.Services
@using jihadkhawaja.chat.shared.Models
@using Microsoft.AspNetCore.Components.Forms
@using System.Diagnostics
@using System.Text
@implements IAsyncDisposable
@inherits ProtectedViewBase

@inject SessionStorage SessionStorage
@inject NavigationManager NavigationManager
@inject AgentService AgentService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-0" Style="height: calc(100vh - 64px); display: flex; flex-direction: column;">
    <!-- Header -->
    <MudPaper Elevation="0" Class="px-4 py-2"
              Style="border-bottom: 1px solid rgba(255,255,255,0.08); flex-shrink: 0; background: var(--mud-palette-surface);">
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" Href="/agents" />
                <MudAvatar Color="Color.Primary" Size="Size.Small">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">@Title</MudText>
                    @if (isStreaming)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Primary">Thinking...</MudText>
                    }
                </MudStack>
            </MudStack>
            <MudStack Row Spacing="1">
                <MudMenu Icon="@Icons.Material.Filled.History" Size="Size.Medium" AnchorOrigin="Origin.BottomRight">
                    @if (conversations is not null && conversations.Length > 0)
                    {
                        @foreach (var conv in conversations)
                        {
                            <MudMenuItem OnClick="@(() => SwitchConversation(conv))" Disabled="@(isStreaming || currentConversation?.Id == conv.Id)">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@(currentConversation?.Id == conv.Id ? Icons.Material.Filled.RadioButtonChecked : Icons.Material.Filled.ChatBubble)" Size="Size.Small" />
                                    <MudText Typo="Typo.body2">
                                        @(conv.Title ?? conv.DateCreated?.ToLocalTime().ToString("MMM dd, HH:mm") ?? "Chat")
                                    </MudText>
                                </MudStack>
                            </MudMenuItem>
                        }
                        <MudDivider />
                    }
                    @if (currentConversation is not null)
                    {
                        <MudMenuItem OnClick="DeleteCurrentConversationConfirm" Disabled="@isStreaming">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                                <MudText Typo="Typo.body2" Color="Color.Error">Clear Current Conversation</MudText>
                            </MudStack>
                        </MudMenuItem>
                    }
                    <MudMenuItem OnClick="CreateNewConversation">
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary" />
                            <MudText Typo="Typo.body2" Color="Color.Primary">New Conversation</MudText>
                        </MudStack>
                    </MudMenuItem>
                </MudMenu>
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- Messages -->
    @if (IsBusy)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="flex: 1;">
            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Medium" />
        </MudStack>
    }
    else
    {
        <div id="agent-messages-container" class="chat-messages-scroll"
             style="flex: 1; overflow-x: hidden; overflow-y: auto; padding: 16px 24px;">
            @if (messages.Count == 0 && !isStreaming)
            {
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Large"
                             Style="color: rgba(255,255,255,0.15); font-size: 4rem;" />
                    <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.3);">Start a conversation</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.2);">
                        Send a message to chat with your agent.
                    </MudText>
                </MudStack>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    @if (msg.Role == "user")
                    {
                        <MudStack @key="msg.Id" Row Justify="Justify.FlexEnd" Class="mb-2">
                            <MudPaper Class="pa-3" Elevation="0"
                                      Style="max-width: 75%; border-radius: 16px 16px 4px 16px; background: var(--mud-palette-primary); color: var(--mud-palette-primary-text);">
                                <MarkdownContent @key="msg.RenderKey" Content="@msg.Content" />
                            </MudPaper>
                        </MudStack>
                    }
                    else
                    {
                        <MudStack @key="msg.Id" Row Justify="Justify.FlexStart" Spacing="2" Class="mb-2">
                            <MudAvatar Color="Color.Secondary" Size="Size.Small" Style="align-self: flex-end;">
                                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                            </MudAvatar>
                            <MudPaper Class="pa-3" Elevation="0"
                                      Style="max-width: 75%; border-radius: 16px 16px 16px 4px; background: var(--mud-palette-surface);">
                                <MarkdownContent @key="msg.RenderKey" Content="@msg.Content" />
                            </MudPaper>
                        </MudStack>
                    }
                }

                @if (isStreaming && streamingContent.Length > 0)
                {
                    <MudStack @key="GetStreamingRenderKey()" Row Justify="Justify.FlexStart" Spacing="2" Class="mb-2">
                        <MudAvatar Color="Color.Secondary" Size="Size.Small" Style="align-self: flex-end;">
                            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                        </MudAvatar>
                        <MudPaper Class="pa-3" Elevation="0"
                                  Style="max-width: 75%; border-radius: 16px 16px 16px 4px; background: var(--mud-palette-surface);">
                            <MarkdownContent @key="GetStreamingRenderKey()" Content="@streamingContent.ToString()" />
                        </MudPaper>
                    </MudStack>
                }
                else if (isStreaming)
                {
                    <MudStack Row Justify="Justify.FlexStart" Spacing="2" Class="mb-2">
                        <MudAvatar Color="Color.Secondary" Size="Size.Small" Style="align-self: flex-end;">
                            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                        </MudAvatar>
                        <MudPaper Class="pa-3" Elevation="0"
                                  Style="border-radius: 16px 16px 16px 4px; background: var(--mud-palette-surface);">
                            <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate />
                        </MudPaper>
                    </MudStack>
                }
            }
        </div>

        <!-- Input Area -->
        <div style="flex-shrink: 0; padding: 12px 16px 16px; background: var(--mud-palette-background);">
            <div class="channel-composer-shell">
                <MudFileUpload @ref="attachmentUpload"
                               T="IReadOnlyList<IBrowserFile>"
                               Hidden="true"
                               Files="pendingAttachmentFiles"
                               MaximumFileCount="1"
                               FilesChanged="OnAttachmentFilesChanged">
                    <CustomContent>
                        <MudTooltip Text="Attach document or image">
                            <MudIconButton Icon="@Icons.Material.Filled.AttachFile"
                                           Color="Color.Default"
                                           Size="Size.Medium"
                                           Class="channel-composer-attach"
                                           OnClick="@context.OpenFilePickerAsync"
                                           Disabled="@(isStreaming || isAttachmentBusy)" />
                        </MudTooltip>
                    </CustomContent>
                </MudFileUpload>
                <MudTextField @ref="inputMudTextField"
                              @bind-Value="inputMessage"
                              Underline="false"
                              Variant="Variant.Text"
                              Placeholder="Type a message..."
                              Disabled="@(isStreaming || isAttachmentBusy)"
                              Immediate
                              Lines="1"
                              MaxLines="5"
                              Sizing="InputSizing.Auto"
                              Class="agent-chat-composer-input" />
                <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" Size="Size.Medium"
                               Variant="Variant.Filled"
                               Class="channel-composer-send"
                               OnClick="SendMessage"
                               Disabled="@(isStreaming || isAttachmentBusy || !CanSendMessage)" />
            </div>
            @if (stagedAttachment is not null)
            {
                <MudPaper Class="channel-composer-attachment mt-2 px-3 py-2" Elevation="0">
                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@stagedAttachment.FileName</MudText>
                            <MudText Typo="Typo.caption" Style="opacity: 0.72;">@stagedAttachment.SummaryText</MudText>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       OnClick="ClearStagedAttachmentAsync"
                                       Disabled="@(isStreaming || isAttachmentBusy)" />
                    </MudStack>
                </MudPaper>
            }
        </div>
    }
</MudContainer>