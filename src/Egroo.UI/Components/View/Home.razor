@inject NavigationManager NavigationManager
@inject SessionStorage SessionStorage

<!-- Transparent top bar -->
<MudAppBar Elevation="0" Style="background: transparent;">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
        <MudImage Src="_content/Egroo.UI/favicon-32x32.png" Alt="Egroo" Width="28" Height="28" />
        <MudText Typo="Typo.h6" Style="font-weight: 700; letter-spacing: -0.02em;">Egroo</MudText>
    </MudStack>
    <MudSpacer />
    <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Size="Size.Medium"
                   Href="https://github.com/jihadkhawaja/Egroo"
                   Target="_blank" Rel="noopener noreferrer" />
    <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/signin"
               EndIcon="@Icons.Material.Filled.ArrowForward">
        Sign In
    </MudButton>
</MudAppBar>

<!-- Hero Section -->
<div style="min-height: calc(100vh - 64px); display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 0 24px;">
    <MudStack AlignItems="AlignItems.Center" Spacing="4" Style="max-width: 720px; text-align: center;">
        <MudAvatar Size="Size.Large" Color="Color.Primary" Style="width: 72px; height: 72px;">
            <MudIcon Icon="@Icons.Material.Filled.Forum" Style="font-size: 2rem;" />
        </MudAvatar>
        <MudText Typo="Typo.h3" Style="font-weight: 800; letter-spacing: -0.03em; line-height: 1.15;">
            Chat on your terms.
            <span style="color: var(--mud-palette-primary);">Self-hosted.</span>
        </MudText>
        <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.55); font-weight: 400; line-height: 1.6; max-width: 560px;">
            Egroo is an open-source real-time messaging platform you own and control.
            Private conversations, AI agents, voice calls &mdash; no third-party servers.
        </MudText>
        <MudStack Row Spacing="3" Justify="Justify.Center" Class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       Href="/signup"
                       Style="border-radius: 12px; padding: 12px 32px; font-size: 1rem; text-transform: none;">
                Get Started
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Large"
                       StartIcon="@Icons.Custom.Brands.GitHub"
                       Href="https://github.com/jihadkhawaja/Egroo"
                       Target="_blank" Rel="noopener noreferrer"
                       Style="border-radius: 12px; padding: 12px 32px; font-size: 1rem; text-transform: none; border-color: rgba(255,255,255,0.2);">
                GitHub
            </MudButton>
        </MudStack>
    </MudStack>
</div>

<!-- Features Section -->
<MudContainer MaxWidth="MaxWidth.Large" Class="pb-16">
    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); height: 100%;">
                <MudStack Spacing="3">
                    <MudAvatar Size="Size.Medium" Style="background: rgba(242,89,34,0.12);">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">End-to-End Encryption</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.55); line-height: 1.6;">
                        Messages are AES-encrypted before storage and deleted once delivered. Your data stays yours.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); height: 100%;">
                <MudStack Spacing="3">
                    <MudAvatar Size="Size.Medium" Style="background: rgba(242,89,34,0.12);">
                        <MudIcon Icon="@Icons.Material.Filled.SmartToy" Color="Color.Primary" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">AI Agents</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.55); line-height: 1.6;">
                        Create personal AI assistants powered by your own LLM providers. Chat, search, and automate.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); height: 100%;">
                <MudStack Spacing="3">
                    <MudAvatar Size="Size.Medium" Style="background: rgba(242,89,34,0.12);">
                        <MudIcon Icon="@Icons.Material.Filled.Call" Color="Color.Primary" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Voice Calls</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.55); line-height: 1.6;">
                        Peer-to-peer WebRTC voice calls with no intermediary. Talk freely with low latency.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); height: 100%;">
                <MudStack Spacing="3">
                    <MudAvatar Size="Size.Medium" Style="background: rgba(242,89,34,0.12);">
                        <MudIcon Icon="@Icons.Material.Filled.Devices" Color="Color.Primary" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Cross-Platform</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.55); line-height: 1.6;">
                        Web, desktop, and mobile via Blazor and .NET MAUI. One codebase, every screen.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); height: 100%;">
                <MudStack Spacing="3">
                    <MudAvatar Size="Size.Medium" Style="background: rgba(242,89,34,0.12);">
                        <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Self-Hosted</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.55); line-height: 1.6;">
                        Deploy on your own infrastructure. Docker-ready with PostgreSQL. Full data sovereignty.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); height: 100%;">
                <MudStack Spacing="3">
                    <MudAvatar Size="Size.Medium" Style="background: rgba(242,89,34,0.12);">
                        <MudIcon Icon="@Icons.Material.Filled.Code" Color="Color.Primary" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Open Source</MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.55); line-height: 1.6;">
                        Apache 2.0 licensed. Inspect, fork, extend. Built with .NET 10, Blazor, SignalR, and MudBlazor.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<!-- Footer -->
<MudPaper Elevation="0" Class="py-6" Style="border-top: 1px solid rgba(255,255,255,0.06); background: transparent;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.35);">
                &copy; @DateTime.Now.Year Egroo &mdash; Open Source Chat Platform
            </MudText>
            <MudStack Row Spacing="2">
                <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small"
                               Href="https://github.com/jihadkhawaja/Egroo"
                               Target="_blank" Rel="noopener noreferrer"
                               Style="color: rgba(255,255,255,0.35);" />
            </MudStack>
        </MudStack>
    </MudContainer>
</MudPaper>

@code {
    bool ShouldRenderPage { get; set; } = true;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(SessionStorage.Token) && SessionStorage.User is not null)
        {
            NavigationManager.NavigateTo("/channels");
            ShouldRenderPage = false;
        }
    }

    protected override bool ShouldRender()
    {
        return ShouldRenderPage;
    }
}
