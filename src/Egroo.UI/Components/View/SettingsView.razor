@using BlazorDexie.JsModule
@using Egroo.UI.Models;
@using Egroo.UI.CacheDB

@using jihadkhawaja.chat.shared.Models;
@using Microsoft.AspNetCore.Components.Forms
@inherits ProtectedViewBase

@inject SessionStorage SessionStorage
@inject NavigationManager NavigationManager
@inject StorageService StorageService
@inject IDialogService DialogService
@inject IUser ChatUserService
@inject IJSRuntime JSRuntime
@inject BlazorDexie.Options.BlazorDexieOptions BlazorDexieOptions
@inject EndToEndEncryptionService EndToEndEncryptionService

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <!-- Page Header -->
    <MudStack Spacing="1" Class="mb-4">
        <MudText Typo="Typo.h5" Style="font-weight: 700;">Settings</MudText>
        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.5);">Manage your profile, account, and preferences</MudText>
    </MudStack>

    <!-- Search Filter -->
    <MudTextField @bind-Value="SearchText" Placeholder="Search settings..." Variant="Variant.Outlined"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" DebounceInterval="200"
                  Class="mb-6"
                  Style="border-radius: 12px;" />

    <!-- Loading Spinner -->
    @if (IsBusy)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudProgressCircular Size="Size.Large" Color="Color.Primary" Indeterminate />
        </MudStack>
        return;
    }

    <!-- Profile Section -->
    @if (MatchesSearch("profile", "username", "display name", "first name", "last name", "email"))
    {
        @if (currentUser is not null && currentUser.UserDetail is not null)
        {
            <MudStack Spacing="2" Class="mb-8">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Profile</MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.45);">
                    Your personal information and display preferences
                </MudText>
                <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                          Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                    <MudForm @ref="userForm">
                        <MudStack Spacing="4">
                            <MudText Typo="Typo.overline" Style="color: rgba(255,255,255,0.4); letter-spacing: 1.5px;">PUBLIC</MudText>
                            <MudTextField Value="currentUser.Username" Label="Username" ReadOnly="true" Disabled
                                          Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="currentUser.UserDetail.DisplayName" Label="Display Name"
                                          Variant="Variant.Outlined" />

                            <MudText Typo="Typo.overline" Class="mt-2" Style="color: rgba(255,255,255,0.4); letter-spacing: 1.5px;">PRIVATE</MudText>
                            <MudTextField @bind-Value="currentUser.UserDetail.FirstName" Label="First Name"
                                          Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="currentUser.UserDetail.LastName" Label="Last Name"
                                          Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="currentUser.UserDetail.Email" Label="Email"
                                          Variant="Variant.Outlined" />
                            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="UpdateUserDetails"
                                       Style="border-radius: 12px; height: 44px; text-transform: none; align-self: flex-start;">
                                Save Changes
                            </MudButton>
                        </MudStack>
                    </MudForm>
                </MudPaper>
            </MudStack>
        }
    }

    <!-- Avatar Section -->
    @if (MatchesSearch("avatar", "image", "photo", "picture", "upload"))
    {
        <MudStack Spacing="2" Class="mb-8">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Avatar</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.45);">
                Customize your profile picture
            </MudText>
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                <MudStack Spacing="4">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="4">
                        @if (!string.IsNullOrEmpty(newAvatarPreview))
                        {
                            <MudAvatar Size="Size.Large" Style="width: 72px; height: 72px;">
                                <MudImage Src="@newAvatarPreview" Alt="Profile picture image" />
                            </MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Color="Color.Primary" Size="Size.Large" Style="width: 72px; height: 72px; font-size: 1.5rem;">
                                @SessionStorage?.User?.Username?.ToUpper()[0]
                            </MudAvatar>
                        }
                        <MudStack Spacing="1">
                            <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                            Accept="image/*"
                            MaximumFileCount="1"
                            FilesChanged="OnAvatarFilesChanged">
                                <CustomContent>
                                    <MudButton Color="Color.Default" Variant="Variant.Outlined" OnClick="@context.OpenFilePickerAsync"
                                               Style="border-radius: 10px; text-transform: none; border-color: rgba(255,255,255,0.15);">
                                        Choose Image
                                    </MudButton>
                                </CustomContent>
                            </MudFileUpload>
                            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.35);">
                                Max 10 MB &bull; JPG, PNG, GIF
                            </MudText>
                        </MudStack>
                    </MudStack>
                    @if (!string.IsNullOrEmpty(newAvatarBase64))
                    {
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAvatar"
                                   Style="border-radius: 12px; height: 44px; text-transform: none; align-self: flex-start;">
                            Save Avatar
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>
        </MudStack>
    }

    @if (MatchesSearch("encryption", "security", "keys", "e2ee", "decrypt"))
    {
        <MudStack Spacing="2" Class="mb-8">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">End-to-End Encryption</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.45);">
                Your device holds the private key. The server only stores your public key and cannot decrypt encrypted messages or files.
            </MudText>
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                <MudStack Spacing="3">
                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body1" Style="font-weight: 600;">Device key status</MudText>
                        <MudChip T="string" Color="@(isEncryptionReady ? Color.Success : Color.Warning)" Variant="Variant.Outlined" Size="Size.Small">
                            @(isEncryptionReady ? "Ready" : "Attention required")
                        </MudChip>
                    </MudStack>

                    @if (!string.IsNullOrWhiteSpace(encryptionStatusMessage))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined">
                            @encryptionStatusMessage
                        </MudAlert>
                    }

                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.45);">Key fingerprint</MudText>
                    <MudText Typo="Typo.body2">@FormatKeyId(currentUser?.EncryptionKeyId)</MudText>

                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.45);">Last rotation</MudText>
                    <MudText Typo="Typo.body2">@FormatKeyDate(currentUser?.EncryptionKeyUpdatedOn)</MudText>

                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.7);">
                        Regenerating your key replaces the current device key and clears local cached history because older encrypted messages and files will no longer decrypt on this device.
                    </MudText>

                    <MudButton Color="Color.Warning" Variant="Variant.Outlined" OnClick="RegenerateEncryptionKey"
                               Style="border-radius: 12px; height: 44px; text-transform: none; align-self: flex-start;">
                        Regenerate Encryption Key
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudStack>
    }

    <!-- Account Section -->
    @if (MatchesSearch("account", "sign out", "logout"))
    {
        <MudStack Spacing="2" Class="mb-8">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Size="Size.Small" Color="Color.Info" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Account</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.45);">
                Manage your session and authentication
            </MudText>
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                <MudButton Color="Color.Default" Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.Logout"
                           OnClick="@(() => SignOut())"
                           Style="border-radius: 10px; text-transform: none; align-self: flex-start; border-color: rgba(255,255,255,0.15);">
                    Sign Out
                </MudButton>
            </MudPaper>
        </MudStack>
    }

    <!-- Danger Zone Section -->
    @if (MatchesSearch("delete", "danger", "remove account"))
    {
        <MudStack Spacing="2" Class="mb-8">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Color="Color.Error" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; color: var(--mud-palette-error);">Danger Zone</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.45);">
                Irreversible actions that affect your account permanently
            </MudText>
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,77,77,0.04); border: 1px solid rgba(255,77,77,0.12);">
                <MudButton Color="Color.Error" Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.Delete"
                           OnClick="DeleteUser"
                           Style="border-radius: 10px; text-transform: none; align-self: flex-start;">
                    Delete Account
                </MudButton>
            </MudPaper>
        </MudStack>
    }

    <!-- Feedback Section -->
    @if (MatchesSearch("feedback", "bug", "report", "suggestion"))
    {
        <MudStack Spacing="2" Class="mb-8">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Feedback" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Feedback</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.45);">
                Found a bug or have a suggestion? Let us know
            </MudText>
            <MudPaper Class="pa-6 rounded-xl" Elevation="0"
                      Style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);">
                <MudStack Spacing="4">
                    <MudTextField @bind-Value="FeedbackText" Label="Your feedback" Lines="4" FullWidth="true"
                                  Variant="Variant.Outlined" />
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitFeedback"
                               Style="border-radius: 12px; height: 44px; text-transform: none; align-self: flex-start;">
                        Submit Feedback
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudStack>
    }
</MudContainer>

@code {
    private EgrooDB CacheDB { get; set; } = null!;
    private MudForm userForm = null!;
    private string FeedbackText { get; set; } = string.Empty;
    private string SearchText { get; set; } = string.Empty;
    private UserDto currentUser = new();
    private bool isEncryptionReady;
    private string? encryptionStatusMessage;

    // Variables for avatar update
    private string? newAvatarBase64;
    private string? newAvatarPreview;

    protected override async Task OnAccessAsync()
    {
        IsBusy = true;
        CacheDB = new EgrooDB(BlazorDexieOptions);

        // Retrieve and initialize the current user
        currentUser = SessionStorage.User ?? new UserDto();
        var userWithDetail = await ChatUserService.GetUserPrivateDetails();
        if (userWithDetail is null)
        {
            currentUser.UserDetail = new UserDetail();
        }
        else
        {
            currentUser = userWithDetail;
        }
        await RefreshEncryptionStatusAsync();
        _ = FetchAvatar();
        IsBusy = false;
    }

    private bool MatchesSearch(params string[] keywords)
    {
        if (string.IsNullOrWhiteSpace(SearchText))
            return true;

        return keywords.Any(k => k.Contains(SearchText, StringComparison.OrdinalIgnoreCase));
    }

    private async Task SignOut(bool hasDialog = true)
    {
        if (hasDialog)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to logout? All your locally saved messages will be deleted.",
                yesText: "Logout", cancelText: "Cancel");

            if (!result.HasValue || !result.Value)
            {
                return;
            }
        }

        switch (ClientModel.CurrentFrameworkPlatform)
        {
            case FrameworkPlatform.MAUI:
                string path = Path.Combine(ClientModel.AppDataPath);
                StorageService.DeleteDirectory(path);
                break;
            case FrameworkPlatform.WASM:
            case FrameworkPlatform.SERVER:
                await StorageService.RemoveFromLocalStorage("token");
                break;
            default:
                throw new Exception("CurrentFrameworkPlatform parameter is undefined.");
        }

        await CacheDB.Delete();

        SessionStorage.User = null;

        NavigationManager.NavigateTo("/", true);
    }

    private async Task DeleteUser()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete Account",
            "Are you sure you want to permanently delete your account and all associated data? This action cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (!result.HasValue || !result.Value)
        {
            return;
        }

        await ChatUserService.DeleteUser();
        await SignOut(false);
    }

    private async Task RefreshEncryptionStatusAsync()
    {
        var readiness = await EndToEndEncryptionService.EnsureIdentityAsync(currentUser);
        isEncryptionReady = readiness.IsReady;
        encryptionStatusMessage = readiness.Message;

        if (!readiness.IsReady || readiness.Identity is null)
        {
            return;
        }

        currentUser.EncryptionPublicKey = readiness.Identity.PublicKey;
        currentUser.EncryptionKeyId = readiness.Identity.KeyId;
        currentUser.EncryptionKeyUpdatedOn ??= DateTimeOffset.UtcNow;

        if (SessionStorage.User?.Id == currentUser.Id)
        {
            SessionStorage.User.EncryptionPublicKey = currentUser.EncryptionPublicKey;
            SessionStorage.User.EncryptionKeyId = currentUser.EncryptionKeyId;
            SessionStorage.User.EncryptionKeyUpdatedOn = currentUser.EncryptionKeyUpdatedOn;
        }
    }

    private async Task RegenerateEncryptionKey()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Regenerate Encryption Key",
            "This will replace your current device key, clear local cached history, and older encrypted messages or files will no longer decrypt on this device. Continue?",
            yesText: "Regenerate",
            cancelText: "Cancel");

        if (!result.GetValueOrDefault())
        {
            return;
        }

        var identity = await EndToEndEncryptionService.RegenerateIdentityAsync();
        currentUser.EncryptionPublicKey = identity.PublicKey;
        currentUser.EncryptionKeyId = identity.KeyId;
        currentUser.EncryptionKeyUpdatedOn = DateTimeOffset.UtcNow;

        if (SessionStorage.User?.Id == currentUser.Id)
        {
            SessionStorage.User.EncryptionPublicKey = currentUser.EncryptionPublicKey;
            SessionStorage.User.EncryptionKeyId = currentUser.EncryptionKeyId;
            SessionStorage.User.EncryptionKeyUpdatedOn = currentUser.EncryptionKeyUpdatedOn;
        }

        await CacheDB.Delete();
        CacheDB = new EgrooDB(BlazorDexieOptions);

        await RefreshEncryptionStatusAsync();
        await DialogService.ShowMessageBoxAsync("Encryption Updated", "A new encryption key was generated for this device. Local cached messages were cleared because older encrypted content can no longer be decrypted.", yesText: "OK");
    }

    private static string FormatKeyId(string? keyId)
    {
        if (string.IsNullOrWhiteSpace(keyId))
        {
            return "Not configured";
        }

        return string.Join(" ", Enumerable.Range(0, (keyId.Length + 3) / 4)
            .Select(index => keyId.Substring(index * 4, Math.Min(4, keyId.Length - (index * 4)))));
    }

    private static string FormatKeyDate(DateTimeOffset? date)
    {
        return date?.ToLocalTime().ToString("dd MMM yyyy, h:mm tt") ?? "Never";
    }

    private async Task SubmitFeedback()
    {
        if (string.IsNullOrWhiteSpace(FeedbackText))
        {
            await DialogService.ShowMessageBoxAsync("Feedback", "Please enter your feedback before submitting.");
            return;
        }

        bool success = await ChatUserService.SendFeedback(FeedbackText);
        if (!success)
        {
            await DialogService.ShowMessageBoxAsync("Error", "Failed to submit feedback. Please try again.");
            return;
        }

        bool? confirmationResult = await DialogService.ShowMessageBoxAsync(
            "Feedback Submitted",
            "Thank you for your feedback!",
            yesText: "OK");

        if (confirmationResult.HasValue && confirmationResult.Value)
        {
            FeedbackText = string.Empty;
        }
    }

    private async Task UpdateUserDetails()
    {
        await userForm.ValidateAsync();
        if (!userForm.IsValid)
        {
            await DialogService.ShowMessageBoxAsync("Error", "Please correct the validation errors and try again.");
            return;
        }

        bool isSuccess = await ChatUserService.UpdateDetails(
            displayname: currentUser.UserDetail?.DisplayName,
            email: currentUser.UserDetail?.Email,
            firstname: currentUser.UserDetail?.FirstName,
            lastname: currentUser.UserDetail?.LastName);

        if (!isSuccess)
        {
            await DialogService.ShowMessageBoxAsync("Error", "Couldn't update user details.");
            return;
        }

        bool? result = await DialogService.ShowMessageBoxAsync(
            "User Details Updated",
            "Your user details and security settings have been saved.",
            yesText: "OK");

        if (result.HasValue && result.Value)
        {
            SessionStorage.User = currentUser;
        }
    }

    private async Task OnAvatarFilesChanged(IReadOnlyList<IBrowserFile> files)
    {
        if (files.Any())
        {
            var file = files.First();
            // Check file size against 10 MB limit
            if (file.Size > 10 * 1024 * 1024)
            {
                newAvatarBase64 = null;
                newAvatarPreview = null;
                await DialogService.ShowMessageBoxAsync("Error", "File size exceeds the 10 MB limit.");
                return;
            }
            var buffer = new byte[file.Size];
            await file.OpenReadStream(10 * 1024 * 1024).ReadAsync(buffer);
            newAvatarBase64 = Convert.ToBase64String(buffer);
            newAvatarPreview = $"data:{file.ContentType};base64,{newAvatarBase64}";
        }
    }

    // Save the new avatar using the IUser.UpdateAvatar method
    private async Task SaveAvatar()
    {
        if (string.IsNullOrEmpty(newAvatarBase64))
        {
            return;
        }
        bool success = await ChatUserService.UpdateAvatar(newAvatarBase64);
        if (success)
        {
            await DialogService.ShowMessageBoxAsync("Success", "Avatar updated successfully.");
            // Clear the temporary values
            newAvatarBase64 = null;
            _ = FetchAvatar();
        }
        else
        {
            await DialogService.ShowMessageBoxAsync("Error", "Failed to update avatar. Please try again.");
        }
    }

    private async Task FetchAvatar()
    {
        if (SessionStorage.User is null)
            return;
        
        MediaResult? avatar = await ChatUserService.GetAvatar(SessionStorage.User.Id);

        //new avatar preview after updating (compressed)
        if (avatar is not null)
        {
            newAvatarPreview = SessionStorage.User.CombineAvatarForPreview(avatar);
            await InvokeAsync(StateHasChanged);
        }
    }
}
