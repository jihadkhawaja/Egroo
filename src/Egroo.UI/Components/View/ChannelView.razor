@using BlazorDexie.JsModule
@using Egroo.UI.Helpers
@using Microsoft.AspNetCore.SignalR.Client
@using MudBlazor
@using jihadkhawaja.chat.client
@using jihadkhawaja.chat.client.Services
@using Egroo.UI.CacheDB
@using jihadkhawaja.chat.client.Core

@using jihadkhawaja.chat.shared.Models
@using System.Net.Http.Json
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inherits ProtectedViewBase

@inject SessionStorage SessionStorage
@inject StorageService StorageService
@inject NavigationManager NavigationManager
@inject IUser ChatUserService
@inject IMessageHub ChatMessageService
@inject IChannel ChatChannelService
@inject ChatCallService ChatCallService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject BlazorDexie.Options.BlazorDexieOptions BlazorDexieOptions
@inject AgentService AgentService

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-0" Style="height: calc(100vh - 64px); display: flex; flex-direction: column;">
    <!-- Header -->
    <MudPaper Elevation="0" Class="px-4 py-2"
              Style="border-bottom: 1px solid rgba(255,255,255,0.08); flex-shrink: 0; background: var(--mud-palette-surface);">
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Medium" Href="/channels" />
                <MudAvatar Color="Color.Primary" Size="Size.Small">
                    @Title?.ToUpper()[0]
                </MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">@Title</MudText>
                    @if (CallParticipantIds.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success">
                            @CallParticipantIds.Count in voice call
                        </MudText>
                    }
                </MudStack>
                @if (IsAdmin)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default"
                                   OnClick="EditChannel" />
                }
            </MudStack>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                @if (CallParticipantIds.Count > 0)
                {
                    <MudAvatarGroup Max="3" Spacing="2" MaxColor="Color.Primary" MaxSize="Size.Small">
                        @foreach (var participant in CallParticipantUsers.Values.Take(3))
                        {
                            @if (!string.IsNullOrWhiteSpace(participant.AvatarPreview))
                            {
                                <MudTooltip Text="@participant.Username">
                                    <MudAvatar Size="Size.Small">
                                        <MudImage Src="@participant.AvatarPreview" Alt="@participant.Username" />
                                    </MudAvatar>
                                </MudTooltip>
                            }
                            else
                            {
                                <MudTooltip Text="@participant.Username">
                                    <MudAvatar Color="Color.Secondary" Size="Size.Small">
                                        @participant.Username?.ToUpper()[0]
                                    </MudAvatar>
                                </MudTooltip>
                            }
                        }
                    </MudAvatarGroup>
                }
                <MudTooltip Text="@(IsInCall ? "Leave Voice Call" : "Join Voice Call")">
                    <MudIconButton Icon="@(IsInCall ? Icons.Material.Filled.CallEnd : Icons.Material.Filled.Call)"
                                   Size="Size.Medium"
                                   Color="@(IsInCall ? Color.Error : Color.Default)"
                                   OnClick="OnCallButtonClicked" />
                </MudTooltip>
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- Messages Container -->
    @if (!IsBusy)
    {
        <MudStack Style="flex: 1; min-height: 0; display: flex; flex-direction: column;">
            <div id="messages-container" class="chat-messages-scroll"
                 style="flex: 1; overflow-x: hidden; overflow-y: auto; padding: 16px 24px;">
                @if (!Messages.Any())
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;">
                        <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Size="Size.Large"
                                 Style="color: rgba(255,255,255,0.15); font-size: 4rem;" />
                        <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.3);">No messages yet</MudText>
                        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.2);">
                            Send a message to start the conversation.
                        </MudText>
                    </MudStack>
                }
                else
                {
                    @foreach (var message in Messages)
                    {
                        if (message.DateCreated?.ToLocalTime().Date == DateTime.Today)
                        {
                            <MessageView DisplayName="@message.DisplayName" Content="@message.Content"
                            Date="@message.DateCreated.Value.ToLocalTime().ToString("h:mm tt")"
                            IsCurrentUser="@(IsCurrentUserMessage(message.SenderId) && !IsAgentMessage(message))"
                            IsAgent="@IsAgentMessage(message)"
                            SentOnDate="@message.DateSent" SeenOnDate="@message.DateSeen" />
                        }
                        else if (message.DateCreated?.ToLocalTime().Date >= DateTime.Today.AddDays(-6))
                        {
                            <MessageView DisplayName="@message.DisplayName" Content="@message.Content"
                            Date="@message.DateCreated.Value.ToLocalTime().ToString("ddd, h:mm tt")"
                            IsCurrentUser="@(IsCurrentUserMessage(message.SenderId) && !IsAgentMessage(message))"
                            IsAgent="@IsAgentMessage(message)"
                            SentOnDate="@message.DateSent" SeenOnDate="@message.DateSeen" />
                        }
                        else
                        {
                            <MessageView DisplayName="@message.DisplayName" Content="@message.Content"
                            Date="@message.DateCreated?.ToLocalTime().ToString("dd/MM/yyyy h:mm tt")"
                            IsCurrentUser="@(IsCurrentUserMessage(message.SenderId) && !IsAgentMessage(message))"
                            IsAgent="@IsAgentMessage(message)"
                            SentOnDate="@message.DateSent" SeenOnDate="@message.DateSeen" />
                        }
                    }
                }
            </div>
            <!-- Input Area -->
            <div style="flex-shrink: 0; padding: 12px 16px 16px; background: var(--mud-palette-background); position: relative;">
                @if (showMentionPopup && filteredMentionAgents.Count > 0)
                {
                    <MudPaper Class="pa-2 rounded-lg" Elevation="8"
                              Style="position: absolute; bottom: 100%; left: 16px; right: 16px; max-height: 200px; overflow-y: auto; z-index: 10; background: var(--mud-palette-surface); border: 1px solid rgba(255,255,255,0.12);">
                        <MudStack Spacing="0">
                            @foreach (var agent in filteredMentionAgents)
                            {
                                <MudButton OnClick="@(() => SelectMentionAgent(agent))"
                                           Variant="Variant.Text" Color="Color.Default" FullWidth
                                           Style="justify-content: flex-start; text-transform: none; padding: 6px 12px;">
                                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" Color="Color.Info" />
                                        <MudText Typo="Typo.body2">@agent.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@agent.Provider — @agent.Model</MudText>
                                    </MudStack>
                                </MudButton>
                            }
                        </MudStack>
                    </MudPaper>
                }
                <div style="display: flex; align-items: flex-end; gap: 10px; background: var(--mud-palette-surface); border-radius: 24px; padding: 6px 6px 6px 18px; border: 1px solid rgba(255,255,255,0.08); transition: border-color 0.2s;">
                    <MudTextField @ref="inputMudTextField" Underline="false"
                    Value="InputContent"
                    ValueChanged="@((string s) => OnInputContent(s))" Immediate="true"
                    InputMode="InputMode.text" InputType="InputType.Text"
                    AutoFocus="false"
                    Placeholder="Type a message..." Variant="Variant.Text" OnKeyDown="EnterPressed"
                    Lines="1" MaxLines="5" MaxLength="MaxMessageLength" Disabled="InputDisabled"
                    Sizing="InputSizing.Auto" KeyDownPreventDefault="_preventDefault"
                    Style="flex: 1; margin: 0;" />
                    <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary"
                    Size="Size.Medium" Variant="Variant.Filled"
                    Style="border-radius: 50%; width: 40px; height: 40px; min-width: 40px;"
                    OnClick="SendMessage" ButtonType="ButtonType.Submit" Disabled="InputDisabled" />
                </div>
            </div>
        </MudStack>
    }
    else
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="flex: 1;">
            <MudProgressCircular Indeterminate Size="Size.Medium" Color="Color.Primary" />
        </MudStack>
    }

    <!-- Voice Call Bar (shown when in call) -->
    @if (IsInCall)
    {
        <MudPaper Elevation="0" Class="px-4 py-2"
                  Style="flex-shrink: 0; border-top: 1px solid rgba(255,255,255,0.08); background: rgba(76,175,80,0.08);">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.GraphicEq" Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Color="Color.Success">
                        Voice Connected &mdash; @CallParticipantIds.Count participant@(CallParticipantIds.Count != 1 ? "s" : "")
                    </MudText>
                    @if (CallDuration is not null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default">@CallDuration</MudText>
                    }
                </MudStack>
                <MudStack Row Spacing="2">
                    <MudTooltip Text="@(IsMuted ? "Unmute" : "Mute")">
                        <MudIconButton Icon="@(IsMuted ? Icons.Material.Filled.MicOff : Icons.Material.Filled.Mic)"
                                       Color="@(IsMuted ? Color.Error : Color.Default)"
                                       OnClick="ToggleMute" />
                    </MudTooltip>
                    <MudTooltip Text="Leave Call">
                        <MudIconButton Icon="@Icons.Material.Filled.CallEnd"
                                       Color="Color.Error"
                                       OnClick="LeaveCall" />
                    </MudTooltip>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    <!-- Hidden container for dynamically created remote audio elements -->
    <div id="remote-audio-container" style="display:none;"></div>
</MudContainer>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? ChannelId { get; set; }

    private bool IsAdmin { get; set; }
    private List<Message> Messages { get; set; } = new();
    private MudTextField<string> inputMudTextField { get; set; } = null!;
    private string? InputContent { get; set; }
    private int MaxMessageLength { get; set; } = 300;
    private bool InputDisabled { get; set; }
    private EgrooDB CacheDB { get; set; } = null!;

    bool _preventDefault;

    // Mention autocomplete state
    private AgentDefinition[]? channelAgentDefs;
    private bool showMentionPopup;
    private List<AgentDefinition> filteredMentionAgents = new();
    private string mentionSearchToken = string.Empty;

    // Voice call state
    private bool IsInCall { get; set; } = false;
    private bool IsMuted { get; set; } = false;
    private HashSet<Guid> CallParticipantIds { get; set; } = new();
    private Dictionary<Guid, UserDto> CallParticipantUsers { get; set; } = new();
    private DotNetObjectReference<ChannelView>? dotNetRef;
    private System.Timers.Timer? callTimer;
    private DateTime? callStartTime;
    private string? CallDuration { get; set; }

    // Disposal tracking
    private bool _disposed;
    private bool _needsScrollToBottom;
    private bool _needsScrollToBottomIfNearBottom;

    // Stored event delegates for unsubscription
    private Func<Guid, Guid[], Task>? _onExistingCallParticipants;
    private Func<Guid, Guid, Task>? _onUserJoinedCall;
    private Func<Guid, Guid, Task>? _onUserLeftCall;
    private Func<Guid, Guid, string, Task>? _onReceiveOffer;
    private Func<Guid, Guid, string, Task>? _onReceiveAnswer;
    private Func<Guid, Guid, string, Task>? _onReceiveIceCandidate;
    private Func<Guid, Guid[], Task>? _onChannelCallParticipantsChanged;

    protected override async Task OnAccessAsync()
    {
        IsBusy = true;
        RegisterMessagingEvents();
        RegisterCallEvents();
        CacheDB = new EgrooDB(BlazorDexieOptions);
        Messages = new();

        // Register DotNet object reference for JS interop callbacks
        dotNetRef = DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("webrtcInterop.registerDotNetObject", dotNetRef);

        // Check if there's an existing call in this channel and show participant count
        await RefreshCallParticipants();

        // Load channel agents for @mention autocomplete
        try
        {
            channelAgentDefs = await AgentService.GetChannelAgents(GetChannelId());
        }
        catch
        {
            channelAgentDefs = Array.Empty<AgentDefinition>();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var channelId = GetChannelId();
        if (channelId != Guid.Empty && SessionStorage?.User != null)
        {
            IsAdmin = await ChatChannelService.IsChannelAdmin(channelId, SessionStorage.User.Id);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ChatMessageService.SendPendingMessages();
            var messages = (await CacheDB.Messages
                .Where(nameof(Message.ChannelId))
                .IsEqual(GetChannelId())
                .Limit(50).ToList()) ?? new List<Message>();
            Messages.AddRange(messages);
            Messages = Messages.OrderBy(x => x.DateCreated).ToList();
            _ = UpdateUnseenMessages();
            IsBusy = false;
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
            ScrollToMessagesEnd();
        }

        if (_needsScrollToBottom)
        {
            _needsScrollToBottom = false;
            ScrollToMessagesEnd();
        }
        else if (_needsScrollToBottomIfNearBottom)
        {
            _needsScrollToBottomIfNearBottom = false;
            ScrollToMessagesEndIfNearBottom();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private Guid GetChannelId()
    {
        return Guid.TryParse(ChannelId, out Guid id) ? id : Guid.Empty;
    }

    public async Task EnterPressed(KeyboardEventArgs e)
    {
        bool isSending = (e.Key == "Enter" || e.Key == "NumpadEnter") && !e.ShiftKey;
        _preventDefault = isSending;
        if (isSending && !InputDisabled)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(InputContent))
            return;

        InputDisabled = true;

        Message message = new()
        {
            ChannelId = GetChannelId(),
            DisplayName = SessionStorage?.User?.Username,
            Content = InputContent.Trim(),
            SenderId = SessionStorage.User!.Id,
        };

        if (await ChatMessageService.SendMessage(message))
        {
            await inputMudTextField.ClearAsync();
        }
        else
        {
            Snackbar.Add("Failed to send message, please check your connection and try again.", Severity.Error);
        }

        InputDisabled = false;

        await inputMudTextField.FocusAsync();
    }

    private void ScrollToMessagesEnd()
    {
        JSRuntime.InvokeVoidAsync("scrollToEnd", "messages-container");
    }

    private void ScrollToMessagesEndIfNearBottom()
    {
        JSRuntime.InvokeVoidAsync("scrollToEndIfNearBottom", "messages-container", 150);
    }

    private bool IsCurrentUserMessage(Guid senderId) => senderId == SessionStorage.User?.Id;
    private bool IsAgentMessage(Message msg) => msg.AgentDefinitionId.HasValue && msg.AgentDefinitionId != Guid.Empty;

    private void OnInputContent(string text)
    {
        InputContent = text;
        UpdateMentionPopup(text);
    }

    private void UpdateMentionPopup(string? text)
    {
        if (string.IsNullOrEmpty(text) || channelAgentDefs is null || channelAgentDefs.Length == 0)
        {
            showMentionPopup = false;
            filteredMentionAgents.Clear();
            return;
        }

        // Find the last '@' that isn't inside @<...>
        var lastAt = text.LastIndexOf('@');
        if (lastAt < 0)
        {
            showMentionPopup = false;
            filteredMentionAgents.Clear();
            return;
        }

        // Check if there's a closing '>' after a '<' following this '@' — if so, mention is already completed
        var afterAt = text[(lastAt + 1)..];
        if (afterAt.Contains('>') && afterAt.IndexOf('<') == 0)
        {
            showMentionPopup = false;
            filteredMentionAgents.Clear();
            return;
        }

        // Extract the partial name typed after @  (strip leading '<' if present)
        mentionSearchToken = afterAt.TrimStart('<');

        // Don't show if there's a space and no bracket syntax started (plain @mention completed)
        if (!afterAt.StartsWith("<") && mentionSearchToken.Contains(' '))
        {
            showMentionPopup = false;
            filteredMentionAgents.Clear();
            return;
        }

        filteredMentionAgents = channelAgentDefs
            .Where(a => string.IsNullOrEmpty(mentionSearchToken)
                || a.Name.Contains(mentionSearchToken, StringComparison.OrdinalIgnoreCase))
            .ToList();

        showMentionPopup = filteredMentionAgents.Count > 0;
    }

    private void SelectMentionAgent(AgentDefinition agent)
    {
        if (string.IsNullOrEmpty(InputContent))
            return;

        var lastAt = InputContent.LastIndexOf('@');
        if (lastAt < 0) return;

        var before = InputContent[..lastAt];
        var mention = agent.Name.Contains(' ') ? $"@<{agent.Name}> " : $"@{agent.Name} ";
        InputContent = before + mention;

        showMentionPopup = false;
        filteredMentionAgents.Clear();
        StateHasChanged();
    }

    private async Task UpdateUnseenMessages()
    {
        foreach (var msg in Messages)
        {
            if (msg.DateSeen is null && msg.SenderId != SessionStorage.User?.Id)
            {
                await ChatMessageService.UpdateMessage(msg);
            }
        }
    }

    private void RegisterMessagingEvents()
    {
        ChatSignalR.HubConnection?.On<Message>("ReceiveMessage", async message =>
        {
            if (message.ChannelId != GetChannelId())
                return;

            if (Messages.Any(x => x.Id == message.Id))
            {
                await ChatMessageService.UpdatePendingMessage(message.Id);
                return;
            }

            var senderUser = await ChatUserService.GetUserPublicDetails(message.SenderId);
            // Preserve agent display name; only override for regular user messages
            if (message.AgentDefinitionId is null || message.AgentDefinitionId == Guid.Empty)
            {
                message.DisplayName = senderUser?.Username;
            }
            Messages.Add(message);

            if (message.DateSeen is null && message.SenderId != SessionStorage.User?.Id)
                await ChatMessageService.UpdateMessage(message);

            await CacheDB.Messages.Add(message);
            await ChatMessageService.UpdatePendingMessage(message.Id);
            if (message.SenderId == SessionStorage.User?.Id)
                _needsScrollToBottom = true;
            else
                _needsScrollToBottomIfNearBottom = true;
            await InvokeAsync(StateHasChanged);
        });

        ChatSignalR.HubConnection?.On<Message>("UpdateMessage", async message =>
        {
            if (message.ChannelId != GetChannelId())
                return;

            for (int i = 0; i < Messages.Count; i++)
            {
                if (message.ReferenceId == Messages[i].ReferenceId)
                {
                    Messages[i].Id = message.Id;
                    Messages[i].DateSeen = message.DateSeen;
                    await CacheDB.Messages.Put(Messages[i], Messages[i].ReferenceId);
                    await InvokeAsync(StateHasChanged);
                    return;
                }
            }
        });
    }

    #region Channel Voice Call

    private async Task OnCallButtonClicked()
    {
        if (IsInCall)
        {
            await LeaveCall();
        }
        else
        {
            await JoinCall();
        }
    }

    private async Task JoinCall()
    {
        var channelId = GetChannelId();
        if (channelId == Guid.Empty) return;

        try
        {
            // Acquire microphone and initialize WebRTC
            bool acquired = await JSRuntime.InvokeAsync<bool>("webrtcInterop.joinCall", channelId.ToString());
            if (!acquired)
            {
                Snackbar.Add("Could not access microphone. Please check permissions.", Severity.Error);
                return;
            }

            // Join the channel call via SignalR
            await ChatCallService.JoinChannelCall(channelId);

            IsInCall = true;
            CallParticipantIds.Add(SessionStorage.User!.Id);
            await FetchAndCacheParticipant(SessionStorage.User.Id);
            StartCallTimer();
            Snackbar.Add("Joined voice call", Severity.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to join call: {ex.Message}", Severity.Error);
            await JSRuntime.InvokeVoidAsync("webrtcInterop.leaveCall");
        }
    }

    private async Task LeaveCall()
    {
        var channelId = GetChannelId();
        try
        {
            await ChatCallService.LeaveChannelCall(channelId);
        }
        catch { /* ignore signalr errors during cleanup */ }

        await JSRuntime.InvokeVoidAsync("webrtcInterop.leaveCall");

        IsInCall = false;
        IsMuted = false;
        CallParticipantIds.Clear();
        CallParticipantUsers.Clear();
        StopCallTimer();
        Snackbar.Add("Left voice call", Severity.Info);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleMute()
    {
        IsMuted = await JSRuntime.InvokeAsync<bool>("webrtcInterop.toggleMute");
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshCallParticipants()
    {
        try
        {
            var participants = await ChatCallService.GetChannelCallParticipants(GetChannelId());
            if (participants != null && participants.Length > 0)
            {
                CallParticipantIds = new HashSet<Guid>(participants);
                await FetchParticipantUsers(participants);
            }
        }
        catch { /* ignore */ }
    }

    private async Task FetchParticipantUsers(IEnumerable<Guid> userIds)
    {
        foreach (var userId in userIds)
        {
            if (!CallParticipantUsers.ContainsKey(userId))
            {
                await FetchAndCacheParticipant(userId);
            }
        }

        // Remove stale entries
        var staleIds = CallParticipantUsers.Keys.Except(CallParticipantIds).ToList();
        foreach (var id in staleIds)
        {
            CallParticipantUsers.Remove(id);
        }
    }

    private async Task FetchAndCacheParticipant(Guid userId)
    {
        try
        {
            var user = await ChatUserService.GetUserPublicDetails(userId);
            if (user != null)
            {
                // Fetch avatar for preview
                var avatar = await ChatUserService.GetAvatar(userId);
                if (avatar != null)
                {
                    user.AvatarPreview = user.CombineAvatarForPreview(avatar);
                }
                CallParticipantUsers[userId] = user;
            }
        }
        catch { /* ignore fetch errors */ }
    }

    // JS Interop callbacks

    /// <summary>Called from JS when a local ICE candidate is generated for a specific peer.</summary>
    [JSInvokable]
    public async Task OnIceCandidateGenerated(string peerId, string candidateJson)
    {
        if (Guid.TryParse(peerId, out Guid targetUserId))
        {
            await ChatCallService.SendIceCandidateToUser(GetChannelId(), targetUserId, candidateJson);
        }
    }

    /// <summary>Called from JS when a peer connection is lost.</summary>
    [JSInvokable]
    public async Task OnPeerDisconnected(string peerId)
    {
        if (Guid.TryParse(peerId, out Guid userId))
        {
            CallParticipantIds.Remove(userId);
            CallParticipantUsers.Remove(userId);
            await JSRuntime.InvokeVoidAsync("webrtcInterop.removePeer", peerId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RegisterCallEvents()
    {
        // When we join a call, receive the list of existing participants to create offers for
        _onExistingCallParticipants = async (channelId, participantIds) =>
        {
            if (_disposed || channelId != GetChannelId()) return;

            try
            {
                foreach (var participantId in participantIds)
                {
                    if (_disposed) return;
                    CallParticipantIds.Add(participantId);
                    await FetchAndCacheParticipant(participantId);

                    // Create a WebRTC offer for each existing participant
                    string? offerSdp = await JSRuntime.InvokeAsync<string?>(
                        "webrtcInterop.createOfferForPeer", participantId.ToString());

                    if (!string.IsNullOrEmpty(offerSdp) && !_disposed)
                    {
                        await ChatCallService.SendOfferToUser(channelId, participantId, offerSdp);
                    }
                }
                if (!_disposed) await InvokeAsync(StateHasChanged);
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        };
        ChatCallService.OnExistingCallParticipants += _onExistingCallParticipants;

        // When a new user joins the call (they will send us an offer)
        _onUserJoinedCall = async (channelId, userId) =>
        {
            if (_disposed || channelId != GetChannelId()) return;

            CallParticipantIds.Add(userId);
            await FetchAndCacheParticipant(userId);
            try { if (!_disposed) await InvokeAsync(StateHasChanged); }
            catch (ObjectDisposedException) { }
        };
        ChatCallService.OnUserJoinedCall += _onUserJoinedCall;

        // When a user leaves the call
        _onUserLeftCall = async (channelId, userId) =>
        {
            if (_disposed || channelId != GetChannelId()) return;

            CallParticipantIds.Remove(userId);
            CallParticipantUsers.Remove(userId);
            try
            {
                if (!_disposed)
                {
                    await JSRuntime.InvokeVoidAsync("webrtcInterop.removePeer", userId.ToString());
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        };
        ChatCallService.OnUserLeftCall += _onUserLeftCall;

        // When receiving an SDP offer from a peer (we need to create an answer)
        _onReceiveOffer = async (channelId, fromUserId, offerSdp) =>
        {
            if (_disposed || channelId != GetChannelId() || !IsInCall) return;

            try
            {
                string? answerSdp = await JSRuntime.InvokeAsync<string?>(
                    "webrtcInterop.handleOfferFromPeer", fromUserId.ToString(), offerSdp);

                if (!string.IsNullOrEmpty(answerSdp) && !_disposed)
                {
                    await ChatCallService.SendAnswerToUser(channelId, fromUserId, answerSdp);
                }
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        };
        ChatCallService.OnReceiveOffer += _onReceiveOffer;

        // When receiving an SDP answer from a peer
        _onReceiveAnswer = async (channelId, fromUserId, answerSdp) =>
        {
            if (_disposed || channelId != GetChannelId() || !IsInCall) return;

            try
            {
                await JSRuntime.InvokeVoidAsync(
                    "webrtcInterop.handleAnswerFromPeer", fromUserId.ToString(), answerSdp);
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        };
        ChatCallService.OnReceiveAnswer += _onReceiveAnswer;

        // When receiving an ICE candidate from a peer
        _onReceiveIceCandidate = async (channelId, fromUserId, candidateJson) =>
        {
            if (_disposed || channelId != GetChannelId() || !IsInCall) return;

            try
            {
                await JSRuntime.InvokeVoidAsync(
                    "webrtcInterop.addIceCandidateForPeer", fromUserId.ToString(), candidateJson);
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        };
        ChatCallService.OnReceiveIceCandidate += _onReceiveIceCandidate;

        // When the full participant list changes (broadcast to all channel members, not just call participants)
        _onChannelCallParticipantsChanged = async (channelId, participantIds) =>
        {
            if (_disposed || channelId != GetChannelId()) return;

            // Only update the UI avatar list; do NOT touch WebRTC connections here
            CallParticipantIds = new HashSet<Guid>(participantIds);

            // Sync the user cache: add new, remove gone
            var currentSet = new HashSet<Guid>(participantIds);
            var staleKeys = CallParticipantUsers.Keys.Where(k => !currentSet.Contains(k)).ToList();
            foreach (var key in staleKeys) CallParticipantUsers.Remove(key);
            foreach (var pid in participantIds)
            {
                if (_disposed) return;
                await FetchAndCacheParticipant(pid);
            }

            try { if (!_disposed) await InvokeAsync(StateHasChanged); }
            catch (ObjectDisposedException) { }
        };
        ChatCallService.OnChannelCallParticipantsChanged += _onChannelCallParticipantsChanged;
    }

    private void StartCallTimer()
    {
        callStartTime = DateTime.UtcNow;
        CallDuration = "00:00";
        callTimer = new System.Timers.Timer(1000);
        callTimer.Elapsed += (_, _) =>
        {
            if (callStartTime.HasValue)
            {
                var elapsed = DateTime.UtcNow - callStartTime.Value;
                CallDuration = elapsed.TotalHours >= 1
                    ? elapsed.ToString(@"hh\:mm\:ss")
                    : elapsed.ToString(@"mm\:ss");
                InvokeAsync(StateHasChanged);
            }
        };
        callTimer.Start();
    }

    private void StopCallTimer()
    {
        callTimer?.Stop();
        callTimer?.Dispose();
        callTimer = null;
        callStartTime = null;
        CallDuration = null;
    }

    #endregion

    private void EditChannel()
    {
        NavigationManager.NavigateTo($"/channeldetail/{ChannelId}/{Title}");
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;

        // Unsubscribe all event handlers
        if (_onExistingCallParticipants is not null)
            ChatCallService.OnExistingCallParticipants -= _onExistingCallParticipants;
        if (_onUserJoinedCall is not null)
            ChatCallService.OnUserJoinedCall -= _onUserJoinedCall;
        if (_onUserLeftCall is not null)
            ChatCallService.OnUserLeftCall -= _onUserLeftCall;
        if (_onReceiveOffer is not null)
            ChatCallService.OnReceiveOffer -= _onReceiveOffer;
        if (_onReceiveAnswer is not null)
            ChatCallService.OnReceiveAnswer -= _onReceiveAnswer;
        if (_onReceiveIceCandidate is not null)
            ChatCallService.OnReceiveIceCandidate -= _onReceiveIceCandidate;
        if (_onChannelCallParticipantsChanged is not null)
            ChatCallService.OnChannelCallParticipantsChanged -= _onChannelCallParticipantsChanged;

        // Clean up call resources
        StopCallTimer();

        try
        {
            if (IsInCall)
            {
                await JSRuntime.InvokeVoidAsync("webrtcInterop.leaveCall");
            }
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }

        dotNetRef?.Dispose();
    }
}
