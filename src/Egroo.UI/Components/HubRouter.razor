@using Egroo.UI.Components.Layout
@using Egroo.UI.Models
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Headers
@using jihadkhawaja.chat.shared.Interfaces
@using jihadkhawaja.chat.client.Core
@using jihadkhawaja.chat.client.Services
@using Egroo.UI.Constants
@using System.Text.Json

@using jihadkhawaja.chat.shared.Models
@implements IDisposable

@inject SessionStorage SessionStorage
@inject StorageService StorageService
@inject NavigationManager NavigationManager
@inject IUser ChatUserService
@inject IAuthClient ChatAuthService
@inject ISnackbar Snackbar

@if (IsBusy)
{
    <div class="app-init-overlay">
        <img src="@IconAssetUrl" class="app-init-logo" alt="Egroo" />
        <MudProgressLinear Indeterminate Color="Color.Primary" Style="width:180px;" />
    </div>
}
else
{
    <div class="app-content-ready">
        @ChildContent

        @if (ShowReconnectOverlay)
        {
            <div class="signalr-reconnect-overlay" role="alert" aria-live="assertive">
                <div class="signalr-reconnect-card">
                    <div class="signalr-reconnect-badge" aria-hidden="true">
                        <img src="@IconAssetUrl" class="signalr-reconnect-logo" alt="" />
                    </div>

                    @if (IsReconnectRetrying)
                    {
                        <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" Class="signalr-reconnect-spinner" />
                    }

                    <MudText Typo="Typo.caption" Class="signalr-reconnect-kicker">Live chat connection</MudText>
                    <MudText Typo="Typo.h6" Class="signalr-reconnect-title">@ReconnectTitle</MudText>
                    <MudText Typo="Typo.body2" Class="signalr-reconnect-copy">@ReconnectMessage</MudText>

                    @if (!string.IsNullOrWhiteSpace(ReconnectErrorDetail))
                    {
                        <MudText Typo="Typo.caption" Class="signalr-reconnect-detail">@ReconnectErrorDetail</MudText>
                    }

                    @if (IsReconnectFailed)
                    {
                        <div class="signalr-reconnect-actions">
                            <MudButton OnClick="RetrySignalRConnectionAsync"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="_retryingConnection">
                                @(_retryingConnection ? "Retrying..." : "Retry connection")
                            </MudButton>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnRoutingCompleted { get; set; }

    private const int ReconnectOverlayRetryThreshold = 2;

    private bool IsBusy { get; set; } = true;
    private HubConnection? _observedConnection;
    private Func<Exception?, Task>? _reconnectingHandler;
    private Func<string?, Task>? _reconnectedHandler;
    private Func<Exception?, Task>? _closedHandler;
    private CancellationTokenSource? _reconnectOverlayDelayCts;
    private bool _suppressConnectionOverlay;
    private bool _retryingConnection;

    private bool IsReconnectRetrying { get; set; }
    private bool IsReconnectFailed { get; set; }
    private string ReconnectTitle { get; set; } = string.Empty;
    private string ReconnectMessage { get; set; } = string.Empty;
    private string? ReconnectErrorDetail { get; set; }
    private bool ShowReconnectOverlay => IsReconnectRetrying || IsReconnectFailed;
    private string IconAssetUrl => $"{NavigationManager.BaseUri.TrimEnd('/')}/_content/Egroo.UI/icon-128.png";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            bool needsSessionRestore = !string.IsNullOrWhiteSpace(SessionStorage.Token) && SessionStorage.User is null;

            // If the connection is already established, update UI and exit.
            if (ChatSignalR.HubConnection is not null)
            {
                if (needsSessionRestore)
                {
                    await ChatSignalR.HubConnection.DisposeAsync();
                    ChatSignalR.Initialize(Source.HubConnectionURL, SessionStorage.Token);
                }

                AttachConnectionLifecycleHandlers(ChatSignalR.HubConnection);

                if (!needsSessionRestore &&
                    (ChatSignalR.HubConnection.State is HubConnectionState.Connected or HubConnectionState.Connecting or HubConnectionState.Reconnecting))
                {
                    if (ChatSignalR.HubConnection.State is HubConnectionState.Reconnecting)
                    {
                        ScheduleReconnectOverlay(ChatSignalR.HubConnection, "Trying to restore your chat session.", null);
                    }

                    IsBusy = false;
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                await ChatSignalR.HubConnection.DisposeAsync();
                ChatSignalR.Initialize(Source.HubConnectionURL, SessionStorage.Token);
            }

            // Initialize session
            await LoadCacheAsync();
            await EstablishSessionAsync();
            await SetAppStateAsync(AppState.CONNECTED);
            PrintStateLog();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Initialization error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsBusy = false;
            await InvokeAsync(StateHasChanged);

            await OnRoutingCompleted.InvokeAsync();
        }
    }

    /// <summary>
    /// Loads a token from local storage or file into the session storage.
    /// </summary>
    private async Task LoadCacheAsync()
    {
        if (!string.IsNullOrWhiteSpace(SessionStorage.Token))
            return;

        await SetAppStateAsync(AppState.LOADING_CACHE);

        switch (ClientModel.CurrentFrameworkPlatform)
        {
            case FrameworkPlatform.MAUI:
                SessionStorage.Token = StorageService.ReadFromJsonFile("token", ClientModel.AppDataPath, true);
                break;
            case FrameworkPlatform.WASM:
            case FrameworkPlatform.SERVER:
                SessionStorage.Token = await StorageService.GetFromLocalStorage("token");
                break;
            default:
                throw new Exception("CurrentFrameworkPlatform parameter is undefined.");
        }
    }

    /// <summary>
    /// Establishes a session by refreshing the token (if available) and setting up the SignalR connection.
    /// </summary>
    private async Task EstablishSessionAsync()
    {
        // Initialize and start the SignalR connection using the current token.
        ChatSignalR.Initialize(Source.HubConnectionURL, SessionStorage.Token);
        AttachConnectionLifecycleHandlers(ChatSignalR.HubConnection!);
        await SetAppStateAsync(AppState.ESTABLISHING_CONNECTION);
        await ChatSignalR.HubConnection!.StartAsync();

        // If a token exists, update HttpClient with the cached token and refresh the session.
        if (!string.IsNullOrEmpty(SessionStorage.Token))
        {
            bool restored = await RestoreSessionFromTokenAsync();

            if (!restored)
            {
                return;
            }
        }
    }

    /// <summary>
    /// Stops and restarts the SignalR connection with a new token.
    /// </summary>
    private async Task RestartSignalRConnectionAsync()
    {
        if (ChatSignalR.HubConnection is not null)
        {
            _suppressConnectionOverlay = true;

            try
            {
                await ChatSignalR.HubConnection.StopAsync();
                await ChatSignalR.HubConnection.DisposeAsync();
            }
            finally
            {
                _suppressConnectionOverlay = false;
            }
        }

        ChatSignalR.Initialize(Source.HubConnectionURL, SessionStorage.Token);
        AttachConnectionLifecycleHandlers(ChatSignalR.HubConnection!);
        SessionStorage.AppState = AppState.CREATING_SESSION;
        await InvokeAsync(StateHasChanged);
        if (ChatSignalR.HubConnection is null)
        {
            throw new InvalidOperationException("SignalR connection was not initialized.");
        }

        await ChatSignalR.HubConnection.StartAsync();
    }

    /// <summary>
    /// Updates the token in local storage or file based on the current platform.
    /// </summary>
    private async Task UpdateTokenStorageAsync(string token)
    {
        switch (ClientModel.CurrentFrameworkPlatform)
        {
            case FrameworkPlatform.MAUI:
                StorageService.CreateDirectory(ClientModel.AppDataPath);
                StorageService.WriteToJsonFile("token", ClientModel.AppDataPath, token, false, true);
                break;
            case FrameworkPlatform.WASM:
            case FrameworkPlatform.SERVER:
                await StorageService.SetLocalStorage("token", token);
                break;
            default:
                throw new Exception("CurrentFrameworkPlatform parameter is undefined.");
        }
    }

    /// <summary>
    /// Updates the current app state without triggering a UI re-render.
    /// </summary>
    private Task SetAppStateAsync(AppState appState)
    {
        SessionStorage.AppState = appState;
        return Task.CompletedTask;
    }

    /// <summary>
    /// Signs the user out by clearing token from storage and navigating to the home page.
    /// </summary>
    private async Task SignOutAsync()
    {
        _suppressConnectionOverlay = true;

        switch (ClientModel.CurrentFrameworkPlatform)
        {
            case FrameworkPlatform.MAUI:
                var path = Path.Combine(ClientModel.AppDataPath);
                StorageService.DeleteDirectory(path);
                break;
            case FrameworkPlatform.WASM:
            case FrameworkPlatform.SERVER:
                await StorageService.RemoveFromLocalStorage("token");
                break;
            default:
                throw new Exception("CurrentFrameworkPlatform parameter is undefined.");
        }

        SessionStorage.User = null;
        NavigationManager.NavigateTo("/", true);
    }

    private void AttachConnectionLifecycleHandlers(HubConnection connection)
    {
        if (ReferenceEquals(_observedConnection, connection))
        {
            return;
        }

        DetachConnectionLifecycleHandlers();

        _reconnectingHandler = exception => OnHubReconnectingAsync(connection, exception);
        _reconnectedHandler = connectionId => OnHubReconnectedAsync(connection, connectionId);
        _closedHandler = exception => OnHubClosedAsync(connection, exception);

        connection.Reconnecting += _reconnectingHandler;
        connection.Reconnected += _reconnectedHandler;
        connection.Closed += _closedHandler;

        _observedConnection = connection;
    }

    private void DetachConnectionLifecycleHandlers()
    {
        if (_observedConnection is null)
        {
            return;
        }

        if (_reconnectingHandler is not null)
        {
            _observedConnection.Reconnecting -= _reconnectingHandler;
        }

        if (_reconnectedHandler is not null)
        {
            _observedConnection.Reconnected -= _reconnectedHandler;
        }

        if (_closedHandler is not null)
        {
            _observedConnection.Closed -= _closedHandler;
        }

        _observedConnection = null;
        _reconnectingHandler = null;
        _reconnectedHandler = null;
        _closedHandler = null;
    }

    private Task OnHubReconnectingAsync(HubConnection connection, Exception? exception)
    {
        if (_suppressConnectionOverlay || !ReferenceEquals(_observedConnection, connection))
        {
            return Task.CompletedTask;
        }

        ScheduleReconnectOverlay(connection, "Trying to restore your chat session.", exception);
        return Task.CompletedTask;
    }

    private Task OnHubReconnectedAsync(HubConnection connection, string? connectionId)
    {
        if (!ReferenceEquals(_observedConnection, connection))
        {
            return Task.CompletedTask;
        }

        ClearReconnectState();

        if (SessionStorage.User is not null)
        {
            SessionStorage.User.ConnectionId = connectionId;
        }

        return InvokeAsync(StateHasChanged);
    }

    private Task OnHubClosedAsync(HubConnection connection, Exception? exception)
    {
        if (_suppressConnectionOverlay || !ReferenceEquals(_observedConnection, connection))
        {
            return Task.CompletedTask;
        }

        if (ChatSignalR.HubConnection is not null &&
            !ReferenceEquals(ChatSignalR.HubConnection, connection) &&
            ChatSignalR.HubConnection.State is HubConnectionState.Connected or HubConnectionState.Connecting or HubConnectionState.Reconnecting)
        {
            return Task.CompletedTask;
        }

        CancelReconnectOverlay();
        IsReconnectRetrying = false;
        IsReconnectFailed = true;
        ReconnectTitle = "Chat connection lost";
        ReconnectMessage = "We couldn't reconnect to the server automatically. Retry to restore live messages and presence.";
        ReconnectErrorDetail = ToReconnectErrorDetail(exception);
        return InvokeAsync(StateHasChanged);
    }

    private void ScheduleReconnectOverlay(HubConnection connection, string message, Exception? exception)
    {
        CancelReconnectOverlay();

        var overlayDelay = ChatSignalR.GetAutomaticReconnectElapsedDelay(ReconnectOverlayRetryThreshold);

        if (overlayDelay <= TimeSpan.Zero)
        {
            SetReconnectRetryingState(message, exception);
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        _reconnectOverlayDelayCts = new CancellationTokenSource();
        _ = ShowReconnectOverlayAfterDelayAsync(connection, message, exception, overlayDelay, _reconnectOverlayDelayCts.Token);
    }

    private async Task ShowReconnectOverlayAfterDelayAsync(HubConnection connection, string message, Exception? exception, TimeSpan overlayDelay, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(overlayDelay, cancellationToken);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (cancellationToken.IsCancellationRequested ||
            _suppressConnectionOverlay ||
            !ReferenceEquals(_observedConnection, connection) ||
            connection.State is not HubConnectionState.Reconnecting)
        {
            return;
        }

        SetReconnectRetryingState(message, exception);
        await InvokeAsync(StateHasChanged);
    }

    private void CancelReconnectOverlay()
    {
        _reconnectOverlayDelayCts?.Cancel();
        _reconnectOverlayDelayCts?.Dispose();
        _reconnectOverlayDelayCts = null;
    }

    private void SetReconnectRetryingState(string message, Exception? exception)
    {
        IsReconnectRetrying = true;
        IsReconnectFailed = false;
        ReconnectTitle = "Reconnecting to chat";
        ReconnectMessage = message;
        ReconnectErrorDetail = ToReconnectErrorDetail(exception);
    }

    private void ClearReconnectState()
    {
        CancelReconnectOverlay();
        IsReconnectRetrying = false;
        IsReconnectFailed = false;
        ReconnectTitle = string.Empty;
        ReconnectMessage = string.Empty;
        ReconnectErrorDetail = null;
        _retryingConnection = false;
    }

    private static string? ToReconnectErrorDetail(Exception? exception)
    {
        if (exception is null || string.IsNullOrWhiteSpace(exception.Message))
        {
            return null;
        }

        return exception.Message;
    }

    private async Task RetrySignalRConnectionAsync()
    {
        if (_retryingConnection)
        {
            return;
        }

        _retryingConnection = true;
        SetReconnectRetryingState("Retrying the connection now.", null);
        await InvokeAsync(StateHasChanged);

        try
        {
            EnsureSignalRConnectionInitialized();

            Operation.Response? refreshResponse = null;
            bool tokenChanged = false;

            if (!string.IsNullOrWhiteSpace(SessionStorage.Token))
            {
                refreshResponse = await RefreshAuthenticatedSessionAsync();

                if (refreshResponse is null)
                {
                    return;
                }

                tokenChanged = !string.Equals(SessionStorage.Token, refreshResponse.Token, StringComparison.Ordinal);

                if (tokenChanged)
                {
                    SessionStorage.Token = refreshResponse.Token;
                    ChatAuthService.HttpClient.DefaultRequestHeaders.Authorization =
                        new AuthenticationHeaderValue("Bearer", SessionStorage.Token);
                    await UpdateTokenStorageAsync(SessionStorage.Token);
                }
            }

            if (tokenChanged)
            {
                await RestartSignalRConnectionAsync();
            }
            else if (ChatSignalR.HubConnection!.State == HubConnectionState.Disconnected)
            {
                await ChatSignalR.HubConnection.StartAsync();
            }

            if (refreshResponse is not null)
            {
                await UpdateCurrentUserSessionAsync(refreshResponse);
            }
            else if (SessionStorage.User is not null)
            {
                SessionStorage.User.ConnectionId = ChatSignalR.HubConnection?.ConnectionId;
            }

            await SetAppStateAsync(AppState.CONNECTED);
            ClearReconnectState();
        }
        catch (Exception ex)
        {
            IsReconnectRetrying = false;
            IsReconnectFailed = true;
            ReconnectTitle = "Retry failed";
            ReconnectMessage = "The chat server is still unavailable. Check the server and try again.";
            ReconnectErrorDetail = ToReconnectErrorDetail(ex);
        }
        finally
        {
            _retryingConnection = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void EnsureSignalRConnectionInitialized()
    {
        if (ChatSignalR.HubConnection is not null)
        {
            AttachConnectionLifecycleHandlers(ChatSignalR.HubConnection);
            return;
        }

        ChatSignalR.Initialize(Source.HubConnectionURL, SessionStorage.Token);
        AttachConnectionLifecycleHandlers(ChatSignalR.HubConnection!);
    }

    private async Task<Operation.Response?> RefreshAuthenticatedSessionAsync()
    {
        ChatAuthService.HttpClient.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", SessionStorage.Token);

        var refreshResponse = await ChatAuthService.RefreshSession();

        if (!refreshResponse.Success || string.IsNullOrWhiteSpace(refreshResponse.Token))
        {
            await SignOutAsync();
            return null;
        }

        return refreshResponse;
    }

    private async Task<bool> RestoreSessionFromTokenAsync()
    {
        if (string.IsNullOrWhiteSpace(SessionStorage.Token))
        {
            return true;
        }

        var refreshResponse = await RefreshAuthenticatedSessionAsync();

        if (refreshResponse is null)
        {
            return false;
        }

        bool tokenChanged = !string.Equals(SessionStorage.Token, refreshResponse.Token, StringComparison.Ordinal);

        if (tokenChanged)
        {
            SessionStorage.Token = refreshResponse.Token;
            ChatAuthService.HttpClient.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", SessionStorage.Token);
            await UpdateTokenStorageAsync(SessionStorage.Token);
            await RestartSignalRConnectionAsync();
        }

        await UpdateCurrentUserSessionAsync(refreshResponse);
        return true;
    }

    private async Task UpdateCurrentUserSessionAsync(Operation.Response refreshResponse)
    {
        string username = SessionStorage.User?.Username ?? string.Empty;

        if (string.IsNullOrWhiteSpace(username))
        {
            username = await ChatUserService.GetCurrentUserUsername() ?? string.Empty;
        }

        SessionStorage.User = new UserDto
        {
            Id = refreshResponse.UserId ?? SessionStorage.User?.Id ?? Guid.Empty,
            Username = username,
            ConnectionId = ChatSignalR.HubConnection?.ConnectionId
        };
    }

    /// <summary>
    /// Called from JavaScript when the window is closed.
    /// 
    /// TODO: Use DI to resolve IChatUser rather than creating a new instance.
    /// </summary>
    [JSInvokable]
    public static async Task OnClosedWindow()
    {
        try
        {
            ChatUserService chatUserService = new ChatUserService();
            await chatUserService.CloseUserSession();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    /// <summary>
    /// Prints app state and connection details to the console (only in DEBUG).
    /// </summary>
    private void PrintStateLog()
    {
#if DEBUG
        var log = $"[Egroo] Connection ready | state={SessionStorage.AppState} | framework={ClientModel.CurrentFrameworkPlatform} | connection={FormatConnectionId(SessionStorage.User?.ConnectionId)}";
        Console.WriteLine(log);
#endif
    }

    private static string FormatConnectionId(string? connectionId)
    {
        if (string.IsNullOrWhiteSpace(connectionId))
        {
            return "n/a";
        }

        if (connectionId.Length <= 8)
        {
            return connectionId;
        }

        return $"{connectionId[..4]}...{connectionId[^4..]}";
    }

    public void Dispose()
    {
        CancelReconnectOverlay();
        DetachConnectionLifecycleHandlers();
    }
}
